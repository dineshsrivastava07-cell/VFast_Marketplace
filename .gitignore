# --- Python --- #
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
.coverage.*
htmlcov/
*.log

# --- Node / React / Expo --- #
node_modules/
.pnp
.pnp.js
coverage/
build/
.next/
out/
.expo/
.expo-shared/
dist/
yarn-debug.log*
yarn-error.log*
npm-debug.log*
pnpm-debug.log*
.eslintcache

# --- IDE / OS --- #
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# --- Env files --- #
# Keep .env files tracked so the Emergent deploy step can substitute
# managed values (DB URL, JWT secret, etc.) at deploy time. Use
# .env.example as the template; never commit production secrets here.
!*.example

# --- Build / temp --- #
*.bak
*.tmp
.tmp/
.cache/
tmp/
*.zip

# --- Backend uploads (don't commit user uploads) --- #
backend/uploads/*
!backend/uploads/.gitkeep

# --- Test reports (Emergent) --- #
test_reports/
playwright-report/
test-results/

# --- Emergent run artifacts --- #
.emergent/
